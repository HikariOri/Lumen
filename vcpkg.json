        "docking-experimental",
        "vulkan-binding",
        "glfw-binding",
        "sdl3-binding"
      ]
    },
    {
      "name": "imguizmo",
      "version>=": "2024-05-29#1"
    },
    {
      "name": "imgui-node-editor",
      "version>=": "0.9.3#2"
    },
    {
      "name": "stb",
      "version>=": "2024-07-29#1"
    },
    {
      "name": "shader-slang",
      "version>=": "2025.14.3"
    },
    {
      "name": "sdl3",
      "version>=": "3.2.22",
      "features": ["vulkan"]
    },
    {
      "name": "sdl3-image",
      "version>=": "3.2.4",
